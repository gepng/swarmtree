# Public Swarm gateway for bee-js reads (PRD §7.2)
VITE_BEE_GATEWAY_URL=https://api.gateway.ethswarm.org

# WalletConnect Cloud project id — public-by-design
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Public RPC for ENS resolution (mainnet for ENS; Gnosis only if needed elsewhere)
VITE_MAINNET_RPC_URL=https://eth.llamarpc.com
VITE_GNOSIS_RPC_URL=https://rpc.gnosischain.com
