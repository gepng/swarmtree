# Local Bee light node API (uploads + stamp listing happen here).
# Run your node with CORS open to the dev origin:
#   bee start \
#     --password <PASSWORD> \
#     --swap-enable \
#     --api-addr 127.0.0.1:1633 \
#     --cors-allowed-origins "http://localhost:3000" \
#     --blockchain-rpc-endpoint https://xdai.fairdatasociety.org
# Buy a stamp before first upload: swarm-cli stamp create
VITE_BEE_API_URL=http://localhost:1633

# Public Swarm gateway used to construct shareable read URLs after upload.
# download.gateway serves HTML directly; api.gateway redirects HTML to a
# "forbidden" page for phishing protection.
VITE_SWARM_READ_URL=https://download.gateway.ethswarm.org

# WalletConnect Cloud project id — public-by-design
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Alchemy API key — one key works for both mainnet (ENS resolution) and
# Gnosis Chain (postage stamp registry reads). Get one at
# https://dashboard.alchemy.com (free tier is plenty).
# Note: Vite bakes this into the client bundle, so the key is public.
# Lock it down via Alchemy's Allowed Origins (Apps → Networks).
# If empty, falls through to public RPCs (LlamaRPC, Blast, gnosischain.com, gateway.fm).
VITE_ALCHEMY_API_KEY=
