# Strong, unique password for your Bee node.
# This password encrypts the node's Ethereum keypair on disk. If you LOSE it,
# you lose access to the wallet — and any xBZZ funds in it. Store it in a 2FA-
# protected password manager.
BEE_PASSWORD=

# Optional: override the Gnosis Chain RPC endpoint Bee uses to sync.
# Default (xdai.fairdatasociety.org) is the Ethersphere-maintained archival
# endpoint and is required for first-time stamp-batch sync. Fallbacks (non-
# archival, may give incomplete stamp lists on first sync):
#   https://rpc.gnosischain.com
#   https://gnosis-rpc.publicnode.com
# BEE_RPC_ENDPOINT=https://xdai.fairdatasociety.org
